<?xml version="1.0"?>
<robot name="robot1" xmlns:xacro="http://www.ros.org/wiki/xacro">

    <!-- 색상 정의 -->
    <material name="blue">
        <color rgba="0.0 0.0 1.0 1.0"/>
    </material>

    <material name="red">
        <color rgba="1.0 0.0 0.0 1.0"/>
    </material>

    <material name="green">
        <color rgba="0.0 1.0 0.0 1.0"/>
    </material>

    <material name="black">
        <color rgba="0.0 0.0 0.0 1.0"/>
    </material>

    <material name="gray">
        <color rgba="0.5 0.5 0.5 1.0"/>
    </material>

    <!-- 기준 링크: base_link -->
    <link name="base_link">
        <visual>
            <origin xyz="0.5 0 0.4" rpy="0 0 0"/>
            <geometry>
                <box size="2.0 1.0 0.5"/>
            </geometry>
            <material name="blue"/>
        </visual>

        <collision>
            <origin xyz="0.5 0 0.4" rpy="0 0 0"/>
            <geometry>
                <box size="2.0 1.0 0.5"/>
            </geometry>
        </collision>

        <inertial>
            <origin xyz="0.5 0 0.4" rpy="0 0 0"/>
            <mass value="1.14395"/>
            <inertia
                ixx="0.095329" ixy="0" ixz="0"
                iyy="0.381317" iyz="0"
                izz="0.476646"/>
        </inertial>
    </link>

    <!-- 왼쪽 바퀴 -->
    <link name="left_wheel_link">
        <visual>
            <origin xyz="0 0 0" rpy="1.5708 0 0"/>
            <geometry>
                <cylinder radius="0.4" length="0.2"/>
            </geometry>
            <material name="red"/>
        </visual>

        <collision>
            <origin xyz="0 0 0" rpy="1.5708 0 0"/>
            <geometry>
                <cylinder radius="0.4" length="0.2"/>
            </geometry>
        </collision>
    </link>

    <joint name="left_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="left_wheel_link"/>
        <origin xyz="0.0 0.6 0.4" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
    </joint>

    <!-- 오른쪽 바퀴 -->
    <link name="right_wheel_link">
        <visual>
            <origin xyz="0 0 0" rpy="1.5708 0 0"/>
            <geometry>
                <cylinder radius="0.4" length="0.2"/>
            </geometry>
            <material name="red"/>
        </visual>

        <collision>
            <origin xyz="0 0 0" rpy="1.5708 0 0"/>
            <geometry>
                <cylinder radius="0.4" length="0.2"/>
            </geometry>
        </collision>
    </link>

    <joint name="right_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="right_wheel_link"/>
        <origin xyz="0.0 -0.6 0.4" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
    </joint>

    <!-- 캐스터 바퀴 -->
    <link name="caster_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <sphere radius="0.2"/>
            </geometry>
            <material name="green"/>
        </visual>

        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <sphere radius="0.2"/>
            </geometry>
        </collision>
    </link>

    <joint name="caster_joint" type="fixed">
        <parent link="base_link"/>
        <child link="caster_link"/>
        <origin xyz="1.3 0 0.2" rpy="0 0 0"/>
    </joint>

    <!-- LiDAR 링크 -->
    <link name="lidar_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <cylinder radius="0.12" length="0.08"/>
            </geometry>
            <material name="black"/>
        </visual>
    </link>

    <joint name="lidar_joint" type="fixed">
        <parent link="base_link"/>
        <child link="lidar_link"/>
        <origin xyz="1.2 0 0.75" rpy="0 0 0"/>
    </joint>

    <!-- 카메라 링크 -->
    <link name="camera_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="0.15 0.08 0.08"/>
            </geometry>
            <material name="gray"/>
        </visual>
    </link>

    <joint name="camera_joint" type="fixed">
        <parent link="base_link"/>
        <child link="camera_link"/>
        <origin xyz="1.5 0 0.65" rpy="0 0 0"/>
    </joint>

    <!-- IMU 링크 -->
    <link name="imu_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="0.12 0.08 0.03"/>
            </geometry>
            <material name="green"/>
        </visual>
    </link>

    <joint name="imu_joint" type="fixed">
        <parent link="base_link"/>
        <child link="imu_link"/>
        <origin xyz="0.5 0 0.7" rpy="0 0 0"/>
    </joint>

</robot>